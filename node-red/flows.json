  {
    "id": "inject-5s", "type": "inject", "z": "tab-collector",
    "name": "5초마다", "repeat": "5", "once": true, "onceDelay": "1",
    "payload": "", "payloadType": "date",
    "x": 110, "y": 80, "wires": [["exec-metrics"]]
  },
  {
    "id": "exec-metrics", "type": "exec", "z": "tab-collector",
    "name": "메트릭 수집", "command": "bash /usr/local/bin/collect_metrics.sh",
    "addpay": false, "useSpawn": false,
    "x": 290, "y": 80, "wires": [["func-parse"], [], []]
  },
  {
    "id": "func-parse", "type": "function", "z": "tab-collector",
    "name": "파싱 & SQL",
    "func": "var parts = msg.payload.trim().split(/\\s+/);\nif (parts.length < 7) { node.warn('파싱 실패'); return null; }\nvar cpu=parseFloat(parts[0])||0, mTot=parseInt(parts[1])||0, mUsed=parseInt(parts[2])||0;\nvar mPct=mTot>0?parseFloat((mUsed/mTot*100).toFixed(2)):0;\nvar dTot=parseInt(parts[3])||0, dUsed=parseInt(parts[4])||0, dPct=parseFloat(parts[5])||0;\nvar nSent=parseInt(parts[6])||0, nRecv=parseInt(parts[7])||0;\nvar data={cpu,mTot,mUsed,mPct,dTot,dUsed,dPct,nSent,nRecv};\nflow.set('lastMetric',data);\nmsg.topic='INSERT INTO system_metrics (cpu_usage,mem_total,mem_used,mem_percent,disk_total,disk_used,disk_percent,net_bytes_sent,net_bytes_recv) VALUES (?,?,?,?,?,?,?,?,?)';\nmsg.payload=[cpu,mTot,mUsed,mPct,dTot,dUsed,dPct,nSent,nRecv];\nnode.status({fill:cpu>80?'red':cpu>60?'yellow':'green',shape:'dot',text:'CPU:'+cpu.toFixed(1)+'% MEM:'+mPct.toFixed(1)+'%'});\nreturn msg;",
    "outputs": 1,
    "x": 480, "y": 80,
    "wires": [["mysql-metrics", "func-alert-check", "func-linux-ui"]]
  },
  {
    "id": "mysql-metrics", "type": "mysql", "z": "tab-collector",
    "name": "MySQL 저장", "mydb": "db-config",
    "x": 700, "y": 40, "wires": [[]]
  },
  {
    "id": "func-alert-check", "type": "function", "z": "tab-collector",
    "name": "임계값 체크",
    "func": "var d=flow.get('lastMetric')||{};\nvar alerts=[];\nif(d.cpu>80)  alerts.push({type:'cpu_high', thr:80, val:d.cpu, msg:'CPU 위험: '+d.cpu.toFixed(1)+'%'});\nif(d.mPct>85) alerts.push({type:'mem_high', thr:85, val:d.mPct,msg:'메모리 위험: '+d.mPct.toFixed(1)+'%'});\nif(d.dPct>90) alerts.push({type:'disk_high',thr:90, val:d.dPct,msg:'디스크 위험: '+d.dPct.toFixed(1)+'%'});\nif(!alerts.length) return null;\nvar a=alerts[0];\nmsg.topic='INSERT INTO alert_history (alert_type,threshold,actual_value,message) VALUES (?,?,?,?)';\nmsg.payload=[a.type,a.thr,a.val,a.msg];\nreturn msg;",
    "outputs": 1,
    "x": 700, "y": 120, "wires": [["mysql-alerts"]]
  },
  {
    "id": "mysql-alerts", "type": "mysql", "z": "tab-collector",
    "name": "알림 저장", "mydb": "db-config",
    "x": 900, "y": 120, "wires": [[]]
  },
  {
    "id": "func-linux-ui", "type": "function", "z": "tab-collector",
    "name": "UI 라우팅",
    "func": "var d=flow.get('lastMetric')||{};\nvar cpu=+(d.cpu||0).toFixed(1), mem=+(d.mPct||0).toFixed(1), disk=+(d.dPct||0).toFixed(1);\nvar sentGB=((d.nSent||0)/1073741824).toFixed(3);\nvar recvGB=((d.nRecv||0)/1073741824).toFixed(3);\nreturn [\n  {payload:cpu,  topic:'CPU (%)'},\n  {payload:mem,  topic:'MEM (%)'},\n  {payload:disk, topic:'DISK (%)'},\n  {payload:sentGB+' GB', topic:'송신'},\n  {payload:recvGB+' GB', topic:'수신'}\n];",
    "outputs": 5,
    "x": 700, "y": 200,
    "wires": [
      ["linux-gauge-cpu",  "linux-chart-cpu"],
      ["linux-gauge-mem",  "linux-chart-mem"],
      ["linux-gauge-disk", "linux-chart-disk"],
      ["linux-text-sent"],
      ["linux-text-recv"]
    ]
  },

