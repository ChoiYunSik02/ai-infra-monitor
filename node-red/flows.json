  {
    "id": "win-http-get", "type": "http request", "z": "tab-windows",
    "name": "Windows 최신 데이터", "method": "GET", "ret": "obj",
    "url": "http://django:8000/api/windows/latest/",
    "x": 320, "y": 80, "wires": [["win-func-route"]]
  },
  {
    "id": "win-func-route", "type": "function", "z": "tab-windows",
    "name": "데이터 파싱 & 라우팅",
    "func": "if(!msg.payload||msg.payload.error){node.status({fill:'red',shape:'ring',text:'오프라인'});return null;}\nvar d=msg.payload, cpu=d.cpu||{}, gpu=d.gpu||{}, mem=d.memory||{};\nvar cpuPct=+(cpu.usage_pct||0).toFixed(1);\nvar cpuTmp=+(cpu.temp_package_c||0).toFixed(1);\nvar cpuPwr=+(cpu.power_package_w||0).toFixed(1);\nvar cpuClk=Math.round(cpu.freq_effective_mhz||0);\nvar gpuPct=+(gpu.usage_pct||0).toFixed(1);\nvar gpuTmp=+(gpu.temp_c||0).toFixed(1);\nvar gpuPwr=+(gpu.power_w||0).toFixed(1);\nvar vram=+(gpu.mem_pct||0).toFixed(1);\nvar ramPct=+(mem.percent||0).toFixed(1);\nvar ramStr=(mem.used_gb||0).toFixed(1)+' / '+(mem.total_gb||0).toFixed(1)+' GB';\nnode.status({fill:'green',shape:'dot',text:'CPU:'+cpuPct+'% GPU:'+gpuPct+'% RAM:'+ramPct+'%'});\nreturn[\n  {payload:cpuPct, topic:'CPU (%)'},\n  {payload:cpuTmp, topic:'CPU 온도 (°C)'},\n  {payload:cpuPwr, topic:'CPU 전력 (W)'},\n  {payload:cpuClk+' MHz', topic:'cpu_clk'},\n  {payload:gpuPct, topic:'GPU (%)'},\n  {payload:gpuTmp, topic:'GPU 온도 (°C)'},\n  {payload:gpuPwr, topic:'GPU 전력 (W)'},\n  {payload:vram,   topic:'VRAM (%)'},\n  {payload:ramPct, topic:'RAM (%)'},\n  {payload:ramStr, topic:'ram_detail'}\n];",
    "outputs": 10,
    "x": 560, "y": 80,
    "wires": [
      ["win-gauge-cpu",  "win-chart-cpu"],
      ["win-text-cpu-temp", "win-chart-cpu-temp"],
      ["win-text-cpu-pwr",  "win-chart-cpu-pwr"],
      ["win-text-cpu-clk"],
      ["win-gauge-gpu",  "win-chart-gpu"],
      ["win-text-gpu-temp", "win-chart-gpu-temp"],
      ["win-text-gpu-pwr",  "win-chart-gpu-pwr"],
      ["win-gauge-vram"],
      ["win-gauge-ram",  "win-chart-ram"],
      ["win-text-ram-detail"]
    ]
  },

