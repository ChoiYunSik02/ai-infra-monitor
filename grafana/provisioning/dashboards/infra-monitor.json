    {
      "id": 6,
      "title": "CPU 통계 (최근 15분)",
      "type": "stat",
      "gridPos": {
        "x": 12,
        "y": 8,
        "w": 12,
        "h": 5
      },
      "datasource": {
        "type": "mysql",
        "uid": "P211906C1C32DB77E"
      },
      "targets": [
        {
          "datasource": {
            "type": "mysql",
            "uid": "P211906C1C32DB77E"
          },
          "rawSql": "SELECT NOW() AS time, ROUND(MAX(cpu_usage),1) AS '최대', ROUND(AVG(cpu_usage),1) AS '평균', ROUND(MIN(cpu_usage),1) AS '최소' FROM system_metrics WHERE recorded_at >= NOW() - INTERVAL 15 MINUTE",
          "format": "time_series",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "#22c55e",
                "value": null
              },
              {
                "color": "#facc15",
                "value": 60
              },
              {
                "color": "#ef4444",
                "value": 80
              }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "orientation": "horizontal",
        "textMode": "auto",
        "colorMode": "background"
      }
    },
