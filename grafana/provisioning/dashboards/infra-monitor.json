{
  "title": "AI Infra Monitor",
  "uid": "aim-dashboard",
  "schemaVersion": 38,
  "version": 4,
  "refresh": "5s",
  "time": {
    "from": "now-15m",
    "to": "now"
  },
  "timezone": "browser",
  "style": "dark",
  "panels": [
    {
      "id": 1,
      "title": "CPU 사용률",
      "type": "timeseries",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "mysql",
        "uid": "P211906C1C32DB77E"
      },
      "targets": [
        {
          "datasource": {
            "type": "mysql",
            "uid": "P211906C1C32DB77E"
          },
          "rawSql": "SELECT UNIX_TIMESTAMP(recorded_at)*1000 AS time, cpu_usage AS 'CPU (%)' FROM system_metrics WHERE $__timeFilter(recorded_at) ORDER BY recorded_at ASC",
          "format": "time_series",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "fixed",
            "fixedColor": "#60a5fa"
          },
          "unit": "percent",
          "min": 0,
          "max": 100,
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 25,
            "gradientMode": "opacity",
            "spanNulls": true,
            "showPoints": "never",
            "lineInterpolation": "smooth"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "#facc15",
                "value": 60
              },
              {
                "color": "#ef4444",
                "value": 80
              }
            ]
          },
          "thresholdsStyle": {
            "mode": "line+area"
          }
        }
      },
      "options": {
        "tooltip": {
          "mode": "multi",
          "sort": "none"
        },
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      }
    },
